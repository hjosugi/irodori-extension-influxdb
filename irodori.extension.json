{
  "$schema": "https://irodori.dev/schemas/irodori.extension.schema.json",
  "manifestVersion": 1,
  "id": "irodori.influxdb",
  "name": "InfluxDB Connector",
  "version": "0.1.0",
  "publisher": "irodori",
  "description": "InfluxDB Connector contributes the InfluxDB database connector through the native connector ABI.",
  "license": "MIT OR 0BSD",
  "repository": "https://github.com/hjosugi/irodori-extension-influxdb",
  "apiVersion": "0.1",
  "runtime": "native",
  "entry": "dist/native",
  "permissions": [
    "connections:read",
    "connections:write",
    "queries:run",
    "metadata:read",
    "native",
    "connectors"
  ],
  "contributes": {
    "connectors": [
      {
        "id": "influxdb.connector",
        "engine": "influxdb",
        "label": "InfluxDB",
        "aliases": [
          "influxdb",
          "InfluxDB"
        ],
        "defaultPort": 8086,
        "wire": "influxdb",
        "module": "influxdb.driver",
        "features": [
          "metadata",
          "streaming",
          "timeSeries",
          "timeBuckets",
          "latestValue",
          "queryTemplates",
          "visualization"
        ],
        "connection": {
          "schemaVersion": 1,
          "inferEnvironmentFrom": [
            "name",
            "id",
            "host",
            "database",
            "url"
          ],
          "compatibility": {
            "addsRequiredProfileFields": false,
            "acceptsExistingProfiles": true
          },
          "defaults": {
            "engine": "influxdb",
            "wire": "influxdb",
            "port": 8086,
            "readOnly": false
          },
          "endpoint": {
            "modes": [
              "hostPort",
              "connectionString"
            ],
            "defaultPort": 8086,
            "fields": [
              {
                "id": "host",
                "label": "Host",
                "type": "string",
                "profileField": "host",
                "required": true
              },
              {
                "id": "port",
                "label": "Port",
                "type": "number",
                "profileField": "port",
                "default": 8086
              },
              {
                "id": "database",
                "label": "Organization or bucket",
                "type": "string",
                "profileField": "database"
              }
            ]
          },
          "profileFields": [
            {
              "id": "id",
              "label": "Connection ID",
              "type": "string",
              "profileField": "id",
              "required": true
            },
            {
              "id": "url",
              "label": "Connection URL or DSN",
              "type": "uri",
              "profileField": "url"
            },
            {
              "id": "user",
              "label": "User",
              "type": "string",
              "profileField": "user"
            },
            {
              "id": "host",
              "label": "Host",
              "type": "string",
              "profileField": "host",
              "required": true
            },
            {
              "id": "port",
              "label": "Port",
              "type": "number",
              "profileField": "port",
              "default": 8086
            },
            {
              "id": "database",
              "label": "Organization or bucket",
              "type": "string",
              "profileField": "database"
            },
            {
              "id": "readOnly",
              "label": "Read-only connection",
              "type": "boolean",
              "profileField": "readOnly",
              "default": false
            },
            {
              "id": "options",
              "label": "Driver options",
              "type": "map",
              "profileField": "options"
            }
          ],
          "authMethods": [
            {
              "id": "none",
              "label": "No authentication",
              "kind": "none",
              "secretPurposes": [],
              "fields": []
            },
            {
              "id": "connectionString",
              "label": "Connection string / DSN",
              "kind": "connectionString",
              "secretPurposes": [],
              "fields": [
                {
                  "id": "url",
                  "label": "Connection URL or DSN",
                  "type": "uri",
                  "profileField": "url",
                  "required": true
                }
              ]
            },
            {
              "id": "userPassword",
              "label": "User/password",
              "kind": "userPassword",
              "secretPurposes": [
                "password"
              ],
              "fields": [
                {
                  "id": "user",
                  "label": "User",
                  "type": "string",
                  "profileField": "user"
                },
                {
                  "id": "password",
                  "label": "Password",
                  "type": "secret",
                  "secretPurpose": "password",
                  "profileField": "password"
                }
              ]
            },
            {
              "id": "bearerToken",
              "label": "Bearer token",
              "kind": "token",
              "secretPurposes": [
                "token"
              ],
              "fields": [
                {
                  "id": "token",
                  "label": "Token",
                  "type": "secret",
                  "secretPurpose": "token"
                }
              ]
            },
            {
              "id": "apiKey",
              "label": "API key",
              "kind": "apiKey",
              "secretPurposes": [
                "token"
              ],
              "fields": [
                {
                  "id": "apiKey",
                  "label": "API key",
                  "type": "secret",
                  "secretPurpose": "token"
                }
              ]
            },
            {
              "id": "clientCertificate",
              "label": "Client certificate / mTLS",
              "kind": "certificate",
              "secretPurposes": [
                "privateKey",
                "privateKeyPassphrase"
              ],
              "fields": [
                {
                  "id": "clientCertificate",
                  "label": "Client certificate",
                  "type": "pem"
                },
                {
                  "id": "clientPrivateKey",
                  "label": "Client private key",
                  "type": "pem",
                  "secretPurpose": "privateKey"
                },
                {
                  "id": "clientPrivateKeyPassphrase",
                  "label": "Private key passphrase",
                  "type": "secret",
                  "secretPurpose": "privateKeyPassphrase"
                }
              ]
            },
            {
              "id": "customDriverOptions",
              "label": "Custom driver options",
              "kind": "custom",
              "secretPurposes": [
                "password",
                "token",
                "privateKey",
                "privateKeyPassphrase"
              ],
              "fields": [
                {
                  "id": "options",
                  "label": "Driver options",
                  "type": "map",
                  "profileField": "options"
                }
              ]
            }
          ],
          "secretPurposes": [
            "password",
            "token",
            "privateKey",
            "privateKeyPassphrase"
          ],
          "tls": {
            "supported": true,
            "requiredByDefault": false,
            "modes": [
              "disable",
              "prefer",
              "require",
              "verifyCa",
              "verifyFull",
              "clientCertificate"
            ],
            "fields": [
              {
                "id": "caCertificate",
                "label": "CA certificate",
                "type": "pem"
              },
              {
                "id": "clientCertificate",
                "label": "Client certificate",
                "type": "pem"
              },
              {
                "id": "clientPrivateKey",
                "label": "Client private key",
                "type": "pem",
                "secretPurpose": "privateKey"
              }
            ]
          },
          "transports": [
            "direct",
            "sshTunnel",
            "socks5Proxy",
            "httpConnectProxy",
            "proxyChain"
          ],
          "optionNamespaces": [
            "profile.options",
            "driver",
            "tls",
            "network",
            "influxdb"
          ],
          "customDriverOptions": true
        },
        "experience": {
          "schemaVersion": 1,
          "domains": [
            "timeSeries"
          ],
          "inspiredBy": [
            "InfluxDB Data Explorer",
            "Flux aggregateWindow",
            "InfluxDB tasks"
          ],
          "resultViews": [
            "timeChart",
            "table",
            "heatmap"
          ],
          "objectTypes": [
            "buckets",
            "measurements",
            "fields",
            "tags",
            "retentionPolicies",
            "tasks"
          ],
          "workflows": [
            {
              "id": "time-range-query",
              "label": "Time range query",
              "description": "Start every query from a clear time range.",
              "resultView": "timeChart",
              "templateIds": [
                "time-influx-aggregate-window"
              ]
            },
            {
              "id": "time-downsample",
              "label": "Downsample window",
              "description": "Aggregate points into a chart-friendly window.",
              "resultView": "timeChart",
              "templateIds": [
                "time-influx-aggregate-window"
              ]
            },
            {
              "id": "time-latest",
              "label": "Latest values",
              "description": "Read latest values per series key.",
              "resultView": "table",
              "templateIds": [
                "time-influx-latest"
              ]
            }
          ],
          "queryTemplates": [
            {
              "id": "time-influx-aggregate-window",
              "label": "Aggregate window",
              "language": "flux",
              "description": "Downsample a measurement over the last hour.",
              "insertText": "from(bucket: \"$bucket\")\n  |> range(start: -1h)\n  |> filter(fn: (r) => r._measurement == \"$measurement\")\n  |> aggregateWindow(every: 1m, fn: mean, createEmpty: false)\n  |> yield(name: \"mean\")",
              "parameters": [
                {
                  "id": "bucket",
                  "label": "Bucket",
                  "type": "string"
                },
                {
                  "id": "measurement",
                  "label": "Measurement",
                  "type": "string"
                }
              ],
              "resultView": "timeChart"
            },
            {
              "id": "time-influx-latest",
              "label": "Latest values",
              "language": "flux",
              "description": "Return latest values for a measurement.",
              "insertText": "from(bucket: \"$bucket\")\n  |> range(start: -24h)\n  |> filter(fn: (r) => r._measurement == \"$measurement\")\n  |> last()",
              "parameters": [
                {
                  "id": "bucket",
                  "label": "Bucket",
                  "type": "string"
                },
                {
                  "id": "measurement",
                  "label": "Measurement",
                  "type": "string"
                }
              ],
              "resultView": "table"
            }
          ],
          "inspectorHints": [
            {
              "id": "time-field-tag",
              "label": "Field and tag picker",
              "description": "Group fields and tags so chart builders can choose dimensions quickly."
            },
            {
              "id": "time-range",
              "label": "Pinned time range",
              "description": "Carry a reusable time range across Flux templates."
            }
          ]
        }
      }
    ]
  },
  "capabilities": {
    "nativeModules": [
      {
        "id": "influxdb.driver",
        "path": "dist/native",
        "platforms": [
          "windowsX64",
          "windowsArm64",
          "macosX64",
          "macosArm64",
          "linuxX64",
          "linuxArm64"
        ]
      }
    ]
  },
  "dev": {
    "watch": [
      "src",
      "connector.config.json",
      "irodori.extension.json"
    ]
  }
}
